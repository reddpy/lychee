# macOS code signing + notarization
# Copy to `.env` (gitignored) and fill in. Used by `pnpm package:mac` / `pnpm publish:mac`.

# Apple Developer Team ID (10-char). Required to enable signing.
APPLE_TEAM_ID=

# Notarization credentials. Leave blank locally to use the notarytool keychain
# profile `lychee-notarize` (set up via `xcrun notarytool store-credentials`).
# In CI, set all three of these instead.
APPLE_ID=
APPLE_APP_PASSWORD=

# --- CI-only (do not set locally) ---
# These are consumed by the GitHub Actions release workflow to install the
# Developer ID Application cert into a temporary keychain on the runner.
# Set as GitHub Actions repository secrets, not in a local .env.
#
# MACOS_CERT_P12_BASE64
#   The Developer ID Application cert + its private key, exported from
#   Keychain Access as a `.p12` file, then base64-encoded.
#   Example: `base64 -i cert.p12 | gh secret set MACOS_CERT_P12_BASE64`
#
# MACOS_CERT_PASSWORD
#   The password chosen when exporting the `.p12` in Keychain Access.
#   Used by the CI step to unlock the .p12 before importing the identity.
#   Example: `gh secret set MACOS_CERT_PASSWORD`


# =============================================================================
# Windows code signing — Azure Trusted Signing
# Used by `pnpm package:win` / `pnpm make:win` / `pnpm publish:win`.
# Signing is Windows-only (signtool); these have no effect on macOS/Linux.
# Leave blank to skip signing (unsigned local builds).
# =============================================================================

# Trusted Signing account + Public Trust certificate profile (from the Azure
# portal). These identify what gets signed and are NOT secret.
AZURE_CODE_SIGNING_ACCOUNT=
AZURE_CERT_PROFILE=
# Region endpoint shown on the Trusted Signing account Overview page,
# e.g. https://eus.codesigning.azure.net/ (East US).
AZURE_ENDPOINT=

# Service principal credentials — consumed by the Azure dlib via
# DefaultAzureCredential. The principal needs the
# "Trusted Signing Certificate Profile Signer" role on the account.
# These ARE secret: set as GitHub Actions secrets in CI, never commit.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Paths to the signing toolchain. On a local Windows box, point these at your
# installed signtool + the Azure Code Signing dlib (Microsoft.Trusted.Signing.Client).
# In CI these are set automatically by the release workflow. Paths must not
# contain spaces. AZURE_CODE_SIGNING_DLIB must be set for signing to activate.
AZURE_CODE_SIGNING_DLIB=
# Optional: override signtool location (otherwise it must be on PATH).
SIGNTOOL_PATH=
# Optional: override the RFC 3161 timestamp server.
AZURE_TIMESTAMP_URL=http://timestamp.acs.microsoft.com
