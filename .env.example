# macOS code signing + notarization
# Copy to `.env` (gitignored) and fill in. Used by `pnpm package:mac` / `pnpm publish:mac`.

# Apple Developer Team ID (10-char). Required to enable signing.
APPLE_TEAM_ID=

# Notarization credentials. Leave blank locally to use the notarytool keychain
# profile `lychee-notarize` (set up via `xcrun notarytool store-credentials`).
# In CI, set all three of these instead.
APPLE_ID=
APPLE_APP_PASSWORD=
