{
  "name": "lychee",
  "productName": "Lychee",
  "version": "0.1.0-alpha.3",
  "description": "A beautiful, fast, local-first notes app for people who just want to write.",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "package:mac": "dotenv -e .env -- electron-forge package",
    "package:win": "dotenv -e .env -- electron-forge package",
    "make": "electron-forge make",
    "make:mac": "dotenv -e .env -- electron-forge make",
    "make:win": "dotenv -e .env -- electron-forge make",
    "publish": "electron-forge publish",
    "publish:mac": "dotenv -e .env -- electron-forge publish",
    "publish:win": "dotenv -e .env -- electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:build": "E2E=1 pnpm run package && E2E=1 playwright test",
    "rebuild:sqlite": "cd node_modules/better-sqlite3 && npx node-gyp rebuild --release",
    "pretest": "pnpm rebuild:sqlite",
    "build:icons": "node scripts/build-icons.mjs"
  },
  "keywords": [
    "electron",
    "lexical",
    "local-first",
    "notes",
    "sqlite"
  ],
  "homepage": "https://github.com/reddpy/lychee#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reddpy/lychee.git"
  },
  "bugs": {
    "url": "https://github.com/reddpy/lychee/issues"
  },
  "author": {
    "name": "KJ",
    "url": "https://github.com/reddpy"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "fs-xattr",
      "macos-alias",
      "msw"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^2.1.1",
    "@playwright/test": "^1.60.0",
    "@radix-ui/react-slot": "^1.2.4",
